# Copy to .env and fill in. Only OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-...

# Local dev (docker compose exposes postgres on 5432).
# Inside docker compose the app gets its own DATABASE_URL pointing at the db service.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/career_intelligence

# Provider abstraction: which LLM answers chat queries.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
