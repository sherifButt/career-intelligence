# Copy to .env and fill in. Only OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-...

# Local dev (docker compose exposes postgres on host port 5434 to avoid
# clashing with any local postgres on 5432). Inside docker compose the app
# gets its own DATABASE_URL pointing at the db service.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/career_intelligence

# Provider abstraction: which LLM answers chat queries.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Model for the once-per-ingest job screening (stronger judge than chat).
ANALYSIS_MODEL=gpt-4o
